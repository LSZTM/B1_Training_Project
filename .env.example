# Database Connection Configuration
# Copy this file to .env and configure your variables.
# NOTE: These are OPTIONAL. If left blank, the app will show a database picker UI.

# Database Server Address
# Examples: 
#   Local (SQL Express): localhost\SQLEXPRESS
#   Cloud DB: my-server.database.windows.net
DB_SERVER=

# Default Database (used on auto-connect; you can change it from the UI)
DB_DATABASE=

# Driver (auto-detected if left blank)
DB_DRIVER=

# Authentication
# Leave blank for Windows Authentication (Trusted Connection).
# Provide both for SQL Server Authentication.
DB_USERNAME=
DB_PASSWORD=
